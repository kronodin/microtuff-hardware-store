<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Microtuff Hardware Store</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
                    colors: {
                        brand: {
                            DEFAULT: '#f97316',
                            dark: '#c2410c',
                            light: '#fdba74'
                        }
                    }
                }
            }
        };
    </script>
    <style>
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: #020617;
            color: #f1f5f9;
            -webkit-font-smoothing: antialiased;
        }
        /* Hide scrollbar but allow scroll */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .glass {
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
    <!-- React 18 + Babel for JSX -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body class="min-h-screen">
    <div id="root"></div>

    <script type="text/babel" data-type="module">
        const { useState, useEffect, useReducer, createContext, useContext, useMemo, useCallback } = React;

        // ──────────────────────────────────────────────
        // DATA
        // ──────────────────────────────────────────────
        const CATEGORIES = ['All', ...new Set(products.map(p => p.category))];
        const WHATSAPP_NUMBER = '18768036062'; // Microtuff Solutions ordering line

        const products = [
            { id: 'p1', name: '20V Cordless Drill Kit', category: 'Power Tools', price: 129.99, stock: 12, rating: 4.7, image: 'https://images.unsplash.com/photo-1504148455328-c376907d081c?w=800&auto=format&fit=crop', description: 'Lightweight, high-torque drill with 2 batteries and fast charger.', featured: true },
            { id: 'p2', name: '7-1/4" Circular Saw', category: 'Power Tools', price: 149.0, stock: 6, rating: 4.6, image: 'https://images.unsplash.com/photo-1572981779307-38b8cabb2407?w=800&auto=format&fit=crop', description: 'Cuts up to 2-1/2" deep with laser guide and metal blade.', featured: false },
            { id: 'p3', name: '4-1/2" Angle Grinder', category: 'Power Tools', price: 99.0, stock: 8, rating: 4.5, image: 'https://images.unsplash.com/photo-1581092160562-40aa08e78837?w=800&auto=format&fit=crop', description: 'Heavy-duty grinder with adjustable guard for metal and masonry.', featured: false },
            { id: 'p13', name: 'Impact Driver 1/4"', category: 'Power Tools', price: 109.0, stock: 9, rating: 4.6, image: 'https://images.unsplash.com/photo-1504148455328-c376907d081c?w=800&auto=format&fit=crop', description: 'Compact driver with 3-speed settings and LED work light.', featured: false },

            { id: 'p4', name: '16oz Claw Hammer', category: 'Hand Tools', price: 18.5, stock: 25, rating: 4.8, image: 'https://images.unsplash.com/photo-1581141856303-1c2510920042?w=800&auto=format&fit=crop', description: 'Fiberglass handle, magnetic nail starter, and balanced swing weight.', featured: true },
            { id: 'p5', name: '16-Piece Wrench Set', category: 'Hand Tools', price: 54.99, stock: 10, rating: 4.7, image: 'https://images.unsplash.com/photo-1616400619175-5beda3a17896?w=800&auto=format&fit=crop', description: 'Metric and SAE combination wrenches in rugged case.', featured: false },
            { id: 'p6', name: 'Heavy-Duty Screwdriver Set', category: 'Hand Tools', price: 32.99, stock: 18, rating: 4.6, image: 'https://images.unsplash.com/photo-1571455786673-9d6a6d61899b?w=800&auto=format&fit=crop', description: 'Magnetic tips, cushioned grips, and 12 sizes.', featured: false },
            { id: 'p14', name: '25ft Tape Measure', category: 'Hand Tools', price: 15.99, stock: 30, rating: 4.5, image: 'https://images.unsplash.com/photo-1571455786673-9d6a6d61899b?w=800&auto=format&fit=crop', description: 'Locking blade, magnetic hook, and rubberized case.', featured: false },

            { id: 'p7', name: 'Premium Wood Glue', category: 'Building Materials', price: 12.75, stock: 40, rating: 4.4, image: 'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&auto=format&fit=crop', description: 'Waterproof formula with strong bond for woodworking.', featured: false },
            { id: 'p8', name: 'Galvanized Screws Pack', category: 'Building Materials', price: 19.99, stock: 60, rating: 4.5, image: 'https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=800&auto=format&fit=crop', description: '500-pack of rust-resistant screws for framing and sheathing.', featured: false },

            { id: 'p9', name: 'Digital Multimeter', category: 'Electrical & Plumbing', price: 39.99, stock: 15, rating: 4.8, image: 'https://images.unsplash.com/photo-1581092160607-ee22621dd758?w=800&auto=format&fit=crop', description: 'Auto-ranging meter with continuity, AC/DC voltage, and temperature.', featured: true },
            { id: 'p10', name: '50ft Heavy-Duty Extension Cord', category: 'Electrical & Plumbing', price: 34.5, stock: 20, rating: 4.6, image: 'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&auto=format&fit=crop', description: '12-gauge cord with grounded plug and weather-resistant jacket.', featured: false },
            { id: 'p15', name: 'PVC Pipe Repair Kit', category: 'Electrical & Plumbing', price: 27.5, stock: 14, rating: 4.4, image: 'https://images.unsplash.com/photo-1581092160562-40aa08e78837?w=800&auto=format&fit=crop', description: 'Fitting repair clamps, primer, and cement set.', featured: false },

            { id: 'p11', name: 'Anti-Fog Safety Goggles', category: 'Safety & Gear', price: 14.99, stock: 35, rating: 4.7, image: 'https://images.unsplash.com/photo-1616401784675-923b6bb27aa2?w=800&auto=format&fit=crop', description: 'Indirect-vent design for dust, chemical splash, and impact protection.', featured: true },
            { id: 'p12', name: 'Steel-Toe Work Boots', category: 'Safety & Gear', price: 119.99, stock: 7, rating: 4.8, image: 'https://images.unsplash.com/photo-1608231387042-66d1773070a5?w=800&auto=format&fit=crop', description: 'Oil/slip-resistant sole, waterproof leather, and ASTM steel toe.', featured: false },
        ];

        // ──────────────────────────────────────────────
        // STATE: CART
        // ──────────────────────────────────────────────
        const CartContext = createContext();
        const STORAGE_KEY = 'microtuff_hardware_cart';

        function loadCart() {
            try { const raw = localStorage.getItem(STORAGE_KEY); return raw ? JSON.parse(raw) : []; }
            catch { return []; }
        }
        function cartReducer(state, action) {
            switch (action.type) {
                case 'ADD': {
                    const idx = state.findIndex(i => i.id === action.payload.id);
                    if (idx >= 0) { const n = [...state]; n[idx] = { ...n[idx], qty: n[idx].qty + 1 }; return n; }
                    return [...state, { ...action.payload, qty: 1 }];
                }
                case 'REMOVE': return state.filter(i => i.id !== action.payload);
                case 'UPDATE_QTY': {
                    const { id, qty } = action.payload;
                    if (qty <= 0) return state.filter(i => i.id !== id);
                    return state.map(i => (i.id === id ? { ...i, qty } : i));
                }
                case 'CLEAR': return [];
                default: return state;
            }
        }

        function CartProvider({ children }) {
            const [cart, dispatch] = useReducer(cartReducer, [], loadCart);
            useEffect(() => { localStorage.setItem(STORAGE_KEY, JSON.stringify(cart)); }, [cart]);

            const add = item => dispatch({ type: 'ADD', payload: item });
            const remove = id => dispatch({ type: 'REMOVE', payload: id });
            const updateQty = (id, qty) => dispatch({ type: 'UPDATE_QTY', payload: { id, qty } });
            const clear = () => dispatch({ type: 'CLEAR' });
            const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
            const count = cart.reduce((s, i) => s + i.qty, 0);

            return (
                <CartContext.Provider value={{ cart, add, remove, updateQty, clear, total, count }}>
                    {children}
                </CartContext.Provider>
            );
        }
        const useCart = () => useContext(CartContext);

        // ──────────────────────────────────────────────
        // COMPONENTS
        // ──────────────────────────────────────────────
        function CategoryNav({ active, onChange }) {
            return (
                <nav className="flex flex-wrap gap-2 justify-center">
                    {CATEGORIES.map(c => (
                        <button
                            key={c}
                            onClick={() => onChange(c)}
                            className={`px-4 py-2 rounded-xl text-sm font-bold transition ${active === c ? 'bg-brand text-white shadow-lg shadow-brand/20' : 'bg-white/5 text-slate-200 hover:bg-white/10 border border-white/10'}`}
                        >
                            {c}
                        </button>
                    ))}
                </nav>
            );
        }

        function ProductCard({ product, onAdd }) {
            return (
                <div className="group bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-brand/50 hover:shadow-2xl hover:shadow-brand/10 transition duration-300">
                    <div className="aspect-[4/3] overflow-hidden bg-slate-900/40 relative">
                        <img src={product.image} alt={product.name} className="w-full h-full object-cover group-hover:scale-105 transition duration-700" loading="lazy" />
                        {product.featured && (
                            <span className="absolute top-3 left-3 bg-brand text-white text-xs font-bold px-2.5 py-1 rounded-lg">Featured</span>
                        )}
                    </div>
                    <div className="p-4 flex flex-col gap-2.5">
                        <div className="flex items-center justify-between">
                            <span className="text-xs text-brand-light font-bold tracking-wide uppercase">{product.category}</span>
                            <span className="text-xs text-slate-400">★ {product.rating}</span>
                        </div>
                        <h3 className="text-white font-bold text-lg leading-snug">{product.name}</h3>
                        <p className="text-slate-300 text-sm leading-relaxed line-clamp-2">{product.description}</p>
                        <div className="flex items-center justify-between mt-2">
                            <div className="text-white text-2xl font-extrabold">${product.price.toFixed(2)}</div>
                            <button onClick={() => onAdd(product)} className="px-4 py-2.5 bg-brand hover:bg-brand-light text-white rounded-xl font-bold transition shadow-lg shadow-brand/20">
                                Add to Cart
                            </button>
                        </div>
                        <div className="text-xs text-slate-400 font-medium">{product.stock > 0 ? `In Stock: ${product.stock}` : 'Out of Stock'}</div>
                    </div>
                </div>
            );
        }

        function ProductGrid({ category, search, onAdd }) {
            let list = products;
            if (category && category !== 'All') {
                list = list.filter(p => p.category === category);
            }
            if (search.trim()) {
                const q = search.toLowerCase();
                list = list.filter(p => p.name.toLowerCase().includes(q) || p.description.toLowerCase().includes(q) || p.category.toLowerCase().includes(q));
            }
            const sorted = [...list].sort((a, b) => (b.featured ? 1 : 0) - (a.featured ? 1 : 0) || b.rating - a.rating);
            return (
                <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                    {sorted.map(p => (
                        <ProductCard key={p.id} product={p} onAdd={onAdd} />
                    ))}
                    {list.length === 0 && (
                        <div className="col-span-full text-center text-slate-400 py-12">No products found.</div>
                    )}
                </div>
            );
        }

        function CartDrawer({ open, onClose }) {
            const { cart, updateQty, remove, total, count } = useCart();

            if (!open) return null;

            const renderLines = () => cart.map(i => `• ${i.qty}x ${i.name} ($${i.price.toFixed(2)} ea) - $${(i.price * i.qty).toFixed(2)}`).join('\n');

            const submitOrder = (e) => {
                e.preventDefault();
                const fd = new FormData(e.currentTarget);
                const name = String(fd.get('name') || '').trim();
                const phone = String(fd.get('phone') || '').trim();
                const address = String(fd.get('address') || '').trim();
                if (!name || !phone || !address) return alert('Please complete all fields.');
                if (cart.length === 0) return alert('Your cart is empty.');

                const message = `📦 NEW ORDER FROM MICROTUFF HARDWARE\nCustomer: ${name}\nPhone: ${phone}\nAddress: ${address}\n----------------------------------\n${renderLines()}\n----------------------------------\nTotal Amount: $${total.toFixed(2)}`;

                const url = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
                onClose();
                window.open(url, '_blank');
            };

            return (
                <div className="fixed inset-0 z-50">
                    <div className="absolute inset-0 bg-black/60 backdrop-blur-sm" onClick={onClose} />
                    <div className="absolute right-0 top-0 h-full w-full max-w-md bg-slate-900 border-l border-white/10 shadow-2xl flex flex-col">
                        <div className="p-5 border-b border-white/10 flex items-center justify-between">
                            <h2 className="text-white font-bold text-xl">Cart ({count})</h2>
                            <button onClick={onClose} className="text-slate-400 hover:text-white font-semibold">Close</button>
                        </div>

                        <div className="flex-1 overflow-y-auto p-5 space-y-4 no-scrollbar">
                            {cart.length === 0 && (
                                <div className="text-slate-400 text-center py-12">Your cart is empty.<br/>Add power tools, hand tools, materials, and more.</div>
                            )}
                            {cart.map(item => (
                                <div key={item.id} className="flex gap-4 bg-white/5 p-3 rounded-2xl border border-white/10">
                                    <img src={item.image} alt={item.name} className="w-24 h-24 object-cover rounded-xl" />
                                    <div className="flex-1">
                                        <h3 className="text-white font-bold">{item.name}</h3>
                                        <div className="text-brand-light text-sm font-semibold">${item.price.toFixed(2)}</div>
                                        <div className="flex items-center gap-3 mt-2">
                                            <button onClick={() => updateQty(item.id, item.qty - 1)} className="w-8 h-8 flex items-center justify-center bg-white/10 hover:bg-white/20 rounded-xl text-white font-bold transition">-</button>
                                            <span className="text-white w-6 text-center">{item.qty}</span>
                                            <button onClick={() => updateQty(item.id, item.qty + 1)} className="w-8 h-8 flex items-center justify-center bg-white/10 hover:bg-white/20 rounded-xl text-white font-bold transition">+</button>
                                            <button onClick={() => remove(item.id)} className="ml-auto text-red-300 hover:text-red-400 text-sm font-semibold">Remove</button>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>

                        <div className="p-5 border-t border-white/10 space-y-3">
                            <div className="flex justify-between text-white text-xl font-extrabold">
                                <span>Total</span>
                                <span>${total.toFixed(2)}</span>
                            </div>

                            <details className="bg-white/5 border border-white/10 rounded-2xl p-4">
                                <summary className="text-white font-bold cursor-pointer">Complete Order via WhatsApp</summary>
                                <form onSubmit={submitOrder} className="mt-3 grid gap-3">
                                    <input name="name" placeholder="Full Name" className="rounded-xl bg-black/20 border border-white/10 px-4 py-3 text-slate-100 placeholder:text-slate-400 focus:outline-none focus:border-brand" />
                                    <input name="phone" placeholder="Phone Number" className="rounded-xl bg-black/20 border border-white/10 px-4 py-3 text-slate-100 placeholder:text-slate-400 focus:outline-none focus:border-brand" />
                                    <input name="address" placeholder="Delivery Address or Pickup Note" className="rounded-xl bg-black/20 border border-white/10 px-4 py-3 text-slate-100 placeholder:text-slate-400 focus:outline-none focus:border-brand" />
                                    <button type="submit" className="w-full mt-1 px-4 py-3.5 bg-green-500 hover:bg-green-400 text-white rounded-2xl font-extrabold shadow-lg shadow-green-500/20 transition">Place Order on WhatsApp</button>
                                </form>
                            </details>
                        </div>
                    </div>
                </div>
            );
        }

        function HeroBanner() {
            return (
                <section className="relative rounded-3xl border border-white/10 overflow-hidden bg-gradient-to-r from-brand-dark via-brand to-brand-light">
                    <div className="relative px-6 py-16 md:py-24">
                        <div className="max-w-3xl">
                            <span className="inline-block bg-white/20 text-white text-xs font-bold px-3 py-1.5 rounded-lg mb-4">Microtuff Solutions</span>
                            <h1 className="text-4xl md:text-6xl font-black text-white leading-[0.95]">Built for pros.<br/>Priced for everyone.</h1>
                            <p className="mt-4 text-white/90 text-lg md:text-xl max-w-2xl">Power tools, hand tools, building materials, electrical, plumbing, and safety gear. Order faster with WhatsApp checkout.</p>
                            <div className="mt-6 flex flex-wrap gap-3">
                                <a href="#shop" className="px-6 py-3 bg-white text-brand font-bold rounded-2xl shadow-lg hover:shadow-xl transition">Shop Now</a>
                                <a href={/#} onClick={(e) => { e.preventDefault(); document.getElementById('cart-drawer-root')?.querySelector('button')?.click(); }} className="px-6 py-3 bg-white/20 hover:bg-white/30 text-white font-bold rounded-2xl transition backdrop-blur">Open Cart</a>
                            </div>
                        </div>
                        <div className="absolute -right-10 -top-10 w-64 h-64 bg-white/10 rounded-full blur-3xl" />
                        <div className="absolute -right-20 bottom-0 w-96 h-96 bg-white/5 rounded-full blur-3xl" />
                    </div>
                </section>
            );
        }

        // ──────────────────────────────────────────────
        // APP
        // ──────────────────────────────────────────────
        function App() {
            const [category, setCategory] = useState('All');
            const [search, setSearch] = useState('');
            const [cartOpen, setCartOpen] = useState(false);
            const { count } = useCart();

            return (
                <div className="min-h-screen">
                    <header className="sticky top-0 z-40 glass">
                        <div className="max-w-7xl mx-auto px-4 py-3 flex items-center gap-4">
                            <a href="/" className="text-white font-black text-lg md:text-xl tracking-tight whitespace-nowrap">
                                Microtuff <span className="text-brand">Hardware</span>
                            </a>
                            <div className="flex-1 mx-2 md:mx-6">
                                <div className="relative">
                                    <input
                                        value={search}
                                        onChange={e => setSearch(e.target.value)}
                                        placeholder="Search tools, materials, gear..."
                                        className="w-full rounded-2xl bg-white/5 border border-white/10 px-4 py-2.5 text-slate-100 placeholder:text-slate-400 focus:outline-none focus:border-brand transition"
                                    />
                                    <span className="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">⌘K</span>
                                </div>
                            </div>
                            <button onClick={() => setCartOpen(true)} className="relative px-4 py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl transition">
                                <span className="hidden md:inline text-white font-semibold">Cart</span>
                                {count > 0 && <span className="absolute -top-2 -right-2 bg-brand text-white text-xs font-bold w-5 h-5 rounded-full flex items-center justify-center">{count}</span>}
                            </button>
                        </div>
                    </header>

                    <main className="max-w-7xl mx-auto px-4 py-10 space-y-12">
                        <HeroBanner />

                        <section className="space-y-6">
                            <div className="flex items-end justify-between">
                                <h2 className="text-2xl md:text-3xl font-black text-white">Shop Hardware</h2>
                                <p className="text-slate-400 text-sm">{products.length} products</p>
                            </div>
                            <CategoryNav active={category} onChange={setCategory} />
                            <ProductGrid category={category} search={search} onAdd={() => setCartOpen(true)} />
                        </section>
                    </main>

                    <footer className="border-t border-white/10 bg-slate-900/60">
                        <div className="max-w-7xl mx-auto px-4 py-10 grid md:grid-cols-3 gap-8 text-sm text-slate-300">
                            <div>
                                <div className="text-white font-black mb-2">Microtuff Hardware Store</div>
                                <p className="text-slate-400">Trusted tools and materials for contractors, trades, and DIY.</p>
                            </div>
                            <div>
                                <div className="text-white font-black mb-2">Contact</div>
                                <p>+1 (876) 803-6062</p>
                                <p>+1 (770) 580-3927</p>
                                <p>info@microtuffsolutions.com</p>
                            </div>
                            <div>
                                <div className="text-white font-black mb-2">Store Hours</div>
                                <p>Mon - Fri: 8am - 6pm</p>
                                <p>Saturday: 9am - 4pm</p>
                            </div>
                        </div>
                    </footer>

                    <CartDrawer open={cartOpen} onClose={() => setCartOpen(false)} />
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<CartProvider><App /></CartProvider>);
    </script>
</body>
</html>
